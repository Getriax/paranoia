    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.19",
    "@openclaw/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
