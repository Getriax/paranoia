# Paranoia — environment template.
# Copy to .env (gitignored) and fill in OPENROUTER_API_KEY.
#
# Defaults match docker-compose.yml. Change the *_PORT values here AND in
# the URLs if you need to remap host ports.

# --- runtime ---
NODE_ENV=development
PORT=3000

# --- postgres (matches docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=paranoia
POSTGRES_PORT=5432
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/paranoia

# --- dragonfly (matches docker-compose.yml) ---
DRAGONFLY_PORT=6379
DRAGONFLY_URL=redis://localhost:6379

# --- OpenRouter (LLM provider) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODIFIER_DEFAULT_MODEL=deepseek/deepseek-v4-flash

# --- admin (optional) ---
# Used by /admin/* endpoints. Leave unset to disable admin routes locally.
# Generate with: openssl rand -hex 32
# ADMIN_TOKEN=

# --- Engagement analysis (async LLM scoring after each game) ---
# Set to 'false' to disable async LLM analysis (surveys still persist normally).
# Defaults to 'true' when OPENROUTER_API_KEY is set.
ENGAGEMENT_ANALYSIS_ENABLED=true
# Override the model used for engagement analysis (defaults to MODIFIER_DEFAULT_MODEL).
# ENGAGEMENT_MODEL=deepseek/deepseek-v4-flash

# --- Boot-time tasks ---
# Both default to 'true'. Set to 'false' to skip on boot (e.g. multi-instance deploys).
RUN_MIGRATIONS_ON_BOOT=true
RUN_SEED_ON_BOOT=true
